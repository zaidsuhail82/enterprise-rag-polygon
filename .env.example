# ─────────────────────────────────────────────────────────────────────────────
# ENTERPRISE KNOWLEDGE PLATFORM — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── APPLICATION ───────────────────────────────────────────────────────────────
APP_ENV=development               # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-a-long-random-string

# ── GOOGLE DRIVE (G SUITE) ────────────────────────────────────────────────────
# Path to the downloaded JSON key file for your Google service account.
# The service account must have read access to the target Drive folders.
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/service_account.json

# The root folder ID to begin ingestion from.
# Found in the Drive URL: drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-root-folder-id-here

# OAuth2 credentials for user-level Drive access (query-time ACL verification).
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Google Workspace domain (used to restrict SSO login to company accounts only).
GOOGLE_WORKSPACE_DOMAIN=yourcompany.com

# ── VECTOR STORE (QDRANT) ─────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                   # Leave blank for local dev; set for cloud Qdrant
QDRANT_COLLECTION_NAME=enterprise_docs

# ── DATABASE (SUPABASE) ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key   # Server-side only. Never expose client-side.
SUPABASE_ANON_KEY=your-supabase-anon-key              # Safe for frontend auth flows.
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── EMBEDDING MODEL ───────────────────────────────────────────────────────────
# Local model (free, no API cost):
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-mpnet-base-v2

# OpenAI alternative (higher quality, small cost — set EMBEDDING_PROVIDER=openai):
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...

# ── GENERATOR (LLM) ───────────────────────────────────────────────────────────
# Local via Ollama (free, requires GPU for acceptable latency):
GENERATOR_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
GENERATOR_MODEL=mistral               # Pull with: ollama pull mistral

# OpenAI fallback (set GENERATOR_PROVIDER=openai if hardware is insufficient):
# GENERATOR_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# GENERATOR_MODEL=gpt-4o-mini

# ── NLI / HALLUCINATION DETECTION ─────────────────────────────────────────────
NLI_MODEL=cross-encoder/nli-deberta-v3-base
NLI_ENTAILMENT_THRESHOLD=0.7        # Claims below this score are flagged as hallucinated
NLI_DEVICE=cpu                      # cpu | cuda | mps

# ── RETRIEVAL ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20                  # Candidates retrieved before re-ranking
RERANKER_TOP_N=5                    # Passages passed to generator after re-ranking
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
BM25_INDEX_PATH=data/bm25_index.pkl

# ── INGESTION ─────────────────────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=512               # Target chunk size in tokens
CHUNK_OVERLAP_TOKENS=50             # Overlap between consecutive chunks
INGEST_BATCH_SIZE=50                # Documents per embedding batch
SYNC_INTERVAL_MINUTES=15            # How often to poll Drive for changes

# ── ACCESS CONTROL (CLOUDFLARE ZERO TRUST) ────────────────────────────────────
# Your Cloudflare Access team domain (e.g. yourcompany.cloudflareaccess.com)
CF_ACCESS_TEAM_DOMAIN=yourcompany.cloudflareaccess.com
# The Application Audience (AUD) tag from your Cloudflare Access application settings
CF_ACCESS_AUD=your-cloudflare-access-aud-tag

# ── OBSERVABILITY ─────────────────────────────────────────────────────────────
# Langfuse (LLM trace observability — free tier at cloud.langfuse.com or self-hosted)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
